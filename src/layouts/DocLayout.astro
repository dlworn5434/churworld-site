---
import BaseLayout from './BaseLayout.astro';
const { title = '문서', description = '', pathname = '/', badge = '' } = Astro.props;
const heroLabel = badge || title;
---
<BaseLayout title={`${title} | 츄르월드`} description={description} pathname={pathname}>
  <article class="doc-shell">
    <div class="doc-hero">
      <span class="eyebrow">{heroLabel}</span>
      <h1>{title}</h1>
      {description && <p class="muted">{description}</p>}
    </div>
    <div class="doc-body">
      <slot />
    </div>
  </article>
</BaseLayout>
