---
const { title = '츄르월드', description = '츄르월드 공식 사이트', pathname = '/' } = Astro.props;
const nav = [
  { href: '/', label: '홈' },
  { href: '/guide/basic', label: '기본 콘텐츠' },
  { href: '/life', label: '생활 콘텐츠' },
  { href: '/commands', label: '명령어' },
  { href: '/rules', label: '규칙' },
  { href: '/notice', label: '공지' },
  { href: '/terms', label: '이용 약관' }
];
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="/site.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap nav">
        <a href="/" class="brand">
          <span class="brand-badge"></span>
          <span>츄르월드</span>
        </a>
        <nav class="nav-links">
          {nav.map((item) => (
            <a href={item.href} class={pathname === item.href ? 'active' : ''}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer class="footer">
      <div class="wrap">© 2026 츄르월드 · 서버 주소 chur.kr</div>
    </footer>
  </body>
</html>
