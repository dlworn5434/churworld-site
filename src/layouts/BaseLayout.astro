---
const { title = "츄르월드" } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #0f172a;
        --card: #111827;
        --soft: #1f2937;
        --text: #f8fafc;
        --muted: #94a3b8;
        --point: #f59e0b;
        --line: #334155;
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: linear-gradient(180deg, #0f172a 0%, #111827 100%);
        color: var(--text);
        line-height: 1.6;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(1100px, calc(100% - 32px));
        margin: 0 auto;
      }

      header {
        position: sticky;
        top: 0;
        backdrop-filter: blur(10px);
        background: rgba(15, 23, 42, 0.8);
        border-bottom: 1px solid var(--line);
        z-index: 10;
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 0;
      }

      .logo {
        font-size: 22px;
        font-weight: 800;
      }

      .menu {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
      }

      .menu a {
        color: var(--muted);
      }

      .menu a:hover {
        color: var(--text);
      }

      main {
        padding: 48px 0 80px;
      }

      .card {
        background: rgba(17, 24, 39, 0.9);
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 24px;
      }

      h1, h2, h3 {
        line-height: 1.2;
      }

      .btn {
        display: inline-block;
        padding: 12px 16px;
        border-radius: 14px;
        background: var(--point);
        color: #111827;
        font-weight: 800;
        border: 0;
        cursor: pointer;
      }

      .btn.sub {
        background: transparent;
        border: 1px solid var(--line);
        color: var(--text);
      }

      footer {
        border-top: 1px solid var(--line);
        color: var(--muted);
        padding: 24px 0 48px;
      }

      .markdown {
        max-width: 820px;
      }

      .markdown h1,
      .markdown h2,
      .markdown h3 {
        margin-top: 32px;
      }

      .markdown p,
      .markdown li {
        color: #e5e7eb;
      }

      .markdown code {
        background: #0b1220;
        padding: 2px 6px;
        border-radius: 8px;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container nav">
        <a href="/" class="logo">츄르월드</a>
        <nav class="menu">
          <a href="/guide">가이드</a>
          <a href="/rules">규칙</a>
          <a href="/notice">공지</a>
          <a href="/map">지도</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer>
      <div class="container">
        © 2026 츄르월드 · 서버 주소: chur.kr
      </div>
    </footer>
  </body>
</html>
