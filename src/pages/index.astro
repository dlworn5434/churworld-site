---
import BaseLayout from '../layouts/BaseLayout.astro';
const basics = [
  { title: '서버 및 월드', text: '서버 구조와 월드 흐름 안내', status: '준비 중' },
  { title: '마을', href: '/guide/basic/village', text: '클레임, 그룹, 조공, 레벨업까지 정리된 정착 콘텐츠', status: '상세 보기' },
  { title: '잠수 의자', href: '/guide/basic/diving-chair', text: '별 채집과 판매 구조를 담은 잠수 시스템 안내', status: '상세 보기' },
  { title: '엘리베이터', text: '이동 시스템 문서 추가 예정', status: '추가 예정' },
  { title: '상점', text: '거래와 구매 흐름 문서 추가 예정', status: '추가 예정' },
  { title: '가방', text: '가방 시스템 문서 추가 예정', status: '추가 예정' },
  { title: '우편함', text: '우편함 시스템 문서 추가 예정', status: '추가 예정' },
  { title: '길라잡이', text: '초기 적응용 안내 문서 추가 예정', status: '추가 예정' },
];
const lifeLinks = [
  { href: '/life/miner', title: '광부', text: '광물 채굴과 커스텀 광맥을 중심으로 성장하는 생활' },
  { href: '/life/fisher', title: '어부', text: '등급 물고기, 미니게임, 보물과 조각을 노리는 낚시 생활' },
  { href: '/life/farmer', title: '농부', text: '커스텀 작물 수확과 반복 효율을 높이는 재배 생활' },
  { href: '/life/chef', title: '요리사', text: '레시피 조리와 등급 요리 제작을 중심으로 하는 제작 생활' },
];
---
<BaseLayout title="츄르월드 | 공식 홈페이지" description="츄르월드 공식 홈페이지" pathname="/">
  <section class="hero">
    <div class="hero-card">
      <span class="eyebrow">Minecraft Community Server</span>
      <h1>츄르월드</h1>
      <p class="lead">
        서버의 첫인상은 더 고급스럽게, 정보 구조는 더 보기 쉽게.
        처음 온 유저도 필요한 정보를 빠르게 찾고, 기존 유저도 문서 중심으로 편하게 확인할 수 있게 정리한 공식 홈페이지야.
      </p>
      <div class="actions">
        <button class="btn primary" id="copyBtn">IP 복사</button>
        <a class="btn secondary" href="/guide/basic">기본 콘텐츠 보기</a>
        <a class="btn secondary" href="/life">생활 콘텐츠 보기</a>
      </div>
      <div class="hero-meta">
        <div class="mini-stat"><b>chur.kr</b><span class="muted">서버 접속 주소</span></div>
        <div class="mini-stat"><b>문서 허브</b><span class="muted">규칙 / 약관 / 명령어 / 생활 정보 정리</span></div>
        <div class="mini-stat"><b>클릭형 가이드</b><span class="muted">생활 카테고리별 상세 페이지 분리</span></div>
      </div>
    </div>

    <aside class="status-card hero-card">
      <div>
        <div class="status-pill"><span class="status-dot" id="statusDot"></span><span id="statusLabel">상태 확인 중</span></div>
        <h2 style="margin:18px 0 10px; font-size:42px; letter-spacing:-0.04em;">서버 상태</h2>
        <p class="muted" id="statusText">잠시만 기다려줘.</p>
      </div>
      <div class="grid-2" style="margin-top:18px;">
        <div class="card"><h3>콘텐츠</h3><p>기본 콘텐츠와 생활 콘텐츠를 나눠서 직관적으로 찾게 만들었어.</p></div>
        <div class="card"><h3>정보 구조</h3><p>생활마다 상세 페이지를 따로 둬서 클릭해서 보는 방식으로 정리했어.</p></div>
      </div>
    </aside>
  </section>

  <section>
    <div class="section-head">
      <div>
        <div class="kicker">basic contents</div>
        <h2>기본 콘텐츠</h2>
        <p>서버 입문에 필요한 핵심 시스템을 먼저 보여주고, 상세 설명은 가이드 페이지로 이어지게 구성했어.</p>
      </div>
      <a href="/guide/basic" class="btn secondary">기본 콘텐츠 열기</a>
    </div>
    <div class="grid-2 basic-hub-grid">
      {basics.map((item) => (
        item.href ? (
          <a href={item.href} class="card link-card guide-card">
            <span class="tag">기본 콘텐츠</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <span class="link-hint">{item.status}</span>
          </a>
        ) : (
          <div class="card guide-card guide-card--static">
            <span class="tag">기본 콘텐츠</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <span class="soon-badge">{item.status}</span>
          </div>
        )
      ))}
    </div>
  </section>

  <section>
    <div class="section-head">
      <div>
        <div class="kicker">life contents</div>
        <h2>생활 콘텐츠</h2>
        <p>광부 / 어부 / 농부 / 요리사를 각각 따로 클릭해서 볼 수 있게 분리해뒀어.</p>
      </div>
      <a href="/life" class="btn secondary">생활 허브 보기</a>
    </div>
    <div class="grid-2">
      {lifeLinks.map((item) => (
        <a href={item.href} class="card link-card">
          <span class="tag">생활</span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </a>
      ))}
    </div>
  </section>

  <section>
    <div class="section-head">
      <div>
        <div class="kicker">quick links</div>
        <h2>바로가기</h2>
      </div>
    </div>
    <div class="quick-grid">
      <a href="/notice" class="card link-card" aria-label="공지 보기"><span class="tag">업데이트</span><h3>공지</h3><p>점검, 업데이트, 이벤트 안내 확인</p><span class="link-hint">클릭 가능</span></a>
      <a href="/rules" class="card link-card" aria-label="츄르월드 규칙 보기"><span class="tag">정책</span><h3>츄르월드 규칙</h3><p>모든 유저가 지켜야 하는 기본 규칙</p><span class="link-hint">클릭 가능</span></a>
      <a href="/terms" class="card link-card" aria-label="이용 약관 보기"><span class="tag">정책</span><h3>이용 약관</h3><p>서버 이용 전 확인해야 할 정책 문서</p><span class="link-hint">클릭 가능</span></a>
      <a href="/commands" class="card link-card" aria-label="명령어 모음 보기"><span class="tag">문서</span><h3>명령어 모음</h3><p>자주 쓰는 명령어를 한눈에 보기</p></a>
    </div>
  </section>

  <script>
    const addr = 'chur.kr';
    const btn = document.getElementById('copyBtn');
    btn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(addr);
        btn.textContent = '복사 완료';
        setTimeout(() => btn.textContent = 'IP 복사', 1600);
      } catch {
        alert(`직접 복사해줘: ${addr}`);
      }
    });

    const statusDot = document.getElementById('statusDot');
    const statusLabel = document.getElementById('statusLabel');
    const statusText = document.getElementById('statusText');
    async function loadStatus() {
      try {
        const res = await fetch(`https://api.mcsrvstat.us/2/${encodeURIComponent(addr)}`);
        const data = await res.json();
        if (data.online) {
          statusDot.className = 'status-dot online';
          statusLabel.textContent = '온라인';
          statusText.textContent = `현재 접속 인원 ${data.players?.online ?? 0}/${data.players?.max ?? '?'} · 지금 바로 접속 가능`;
        } else {
          statusDot.className = 'status-dot offline';
          statusLabel.textContent = '오프라인';
          statusText.textContent = '현재 서버에 접속할 수 없거나 상태 정보를 불러오지 못했어.';
        }
      } catch {
        statusLabel.textContent = '확인 불가';
        statusText.textContent = '외부 상태 조회에 실패했어.';
      }
    }
    loadStatus();
  </script>
</BaseLayout>
