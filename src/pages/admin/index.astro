---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="관리자 문서 편집 | 츄르월드" description="관리자 전용 문서 편집 페이지" pathname="/admin">
  <section class="admin-shell">
    <div class="section-head">
      <div>
        <div class="kicker">admin only</div>
        <h2>관리자 문서 편집</h2>
        <p>공지, 이용 약관, 규칙, 명령어, 기본/생활 콘텐츠 가이드를 로그인 후 바로 수정할 수 있어.</p>
      </div>
    </div>

    <div id="adminRoot">
      <div class="login-box">
        <h3 style="margin-top:0; font-size:30px; letter-spacing:-0.04em;">관리자 로그인</h3>
        <p class="muted">이 페이지는 관리자 이메일로 로그인한 사람만 수정할 수 있어.</p>

        <div class="field">
          <label for="email">이메일</label>
          <input id="email" type="email" placeholder="admin@example.com" />
        </div>
        <div class="field">
          <label for="password">비밀번호</label>
          <input id="password" type="password" placeholder="비밀번호 입력" />
        </div>
        <button class="btn primary" id="loginBtn" style="width:100%;">로그인</button>
        <div id="loginAlert" class="alert err" style="display:none;"></div>
      </div>
    </div>
  </section>

  <script>
    const root = document.getElementById('adminRoot');
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');
    const loginBtn = document.getElementById('loginBtn');
    const loginAlert = document.getElementById('loginAlert');

    let supabase;
    let currentSession = null;
    let pages = [];
    let selectedSlug = null;

    async function boot() {
      const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
      const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      if (!supabaseUrl || !supabaseKey) {
        root.innerHTML = `
          <div class="doc-error">
            PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY 환경변수가 비어 있어. README_SETUP.md를 보고 Supabase부터 연결해줘.
          </div>
        `;
        return;
      }

      const { createClient } = await import('@supabase/supabase-js');
      supabase = createClient(supabaseUrl, supabaseKey);

      const { data } = await supabase.auth.getSession();
      currentSession = data.session;

      if (currentSession) {
        const ok = await isAdmin();
        if (ok) {
          await renderDashboard();
          return;
        }
        await supabase.auth.signOut();
      }
    }

    async function isAdmin() {
      const { data, error } = await supabase
        .from('admin_emails')
        .select('email')
        .limit(1);
      return !error && Array.isArray(data) && data.length > 0;
    }

    loginBtn?.addEventListener('click', async () => {
      loginAlert.style.display = 'none';
      const email = emailInput.value.trim();
      const password = passwordInput.value;

      if (!email || !password) {
        loginAlert.style.display = 'block';
        loginAlert.textContent = '이메일과 비밀번호를 모두 입력해줘.';
        return;
      }

      const { error } = await supabase.auth.signInWithPassword({ email, password });
      if (error) {
        loginAlert.style.display = 'block';
        loginAlert.textContent = `로그인 실패: ${error.message}`;
        return;
      }

      const ok = await isAdmin();
      if (!ok) {
        loginAlert.style.display = 'block';
        loginAlert.textContent = '이 계정은 관리자 권한이 없어.';
        await supabase.auth.signOut();
        return;
      }

      await renderDashboard();
    });

    async function loadPages() {
      const { data, error } = await supabase
        .from('site_pages')
        .select('slug, nav_title, page_title, excerpt, content_md, updated_at')
        .order('slug');

      if (error) throw error;
      pages = data || [];
      if (!selectedSlug && pages[0]) selectedSlug = pages[0].slug;
    }

    function selectedPage() {
      return pages.find((p) => p.slug === selectedSlug) || pages[0];
    }

    async function renderDashboard() {
      await loadPages();
      const current = selectedPage();

      root.innerHTML = `
        <div class="admin-layout">
          <aside class="admin-sidebar">
            <div class="admin-topbar">
              <div>
                <strong>문서 목록</strong>
                <div class="muted" style="font-size:14px; margin-top:4px;">실시간 수정 가능</div>
              </div>
            </div>
            <div class="admin-list" id="adminList"></div>
            <button class="btn ghost" id="signOutBtn" style="width:100%; margin-top:14px;">로그아웃</button>
          </aside>
          <div class="admin-main">
            <div class="admin-topbar">
              <div>
                <strong id="editorTopTitle">${current?.page_title || ''}</strong>
                <div class="muted" id="editorMeta">${current?.updated_at ? '마지막 수정: ' + new Date(current.updated_at).toLocaleString('ko-KR') : ''}</div>
              </div>
              <div style="display:flex; gap:10px; flex-wrap:wrap;">
                <a class="btn ghost" id="previewLink" href="${previewPath(current?.slug)}" target="_blank" rel="noreferrer">미리 보기</a>
                <button class="btn primary" id="saveBtn">저장</button>
              </div>
            </div>

            <div class="field">
              <label for="navTitle">메뉴 이름</label>
              <input id="navTitle" value="${escapeHtml(current?.nav_title || '')}" />
            </div>
            <div class="field">
              <label for="pageTitle">페이지 제목</label>
              <input id="pageTitle" value="${escapeHtml(current?.page_title || '')}" />
            </div>
            <div class="field">
              <label for="excerpt">짧은 설명</label>
              <input id="excerpt" value="${escapeHtml(current?.excerpt || '')}" />
            </div>
            <div class="field">
              <label for="contentMd">본문 (Markdown)</label>
              <textarea id="contentMd">${escapeTextarea(current?.content_md || '')}</textarea>
            </div>
            <div class="muted" style="font-size:14px;">예시: <code>## 소제목</code>, <code>- 목록</code>, <code>`/command`</code></div>
            <div id="saveAlert" style="display:none;"></div>
          </div>
        </div>
      `;

      const listEl = document.getElementById('adminList');
      pages.forEach((page) => {
        const btn = document.createElement('button');
        btn.className = `admin-item ${page.slug === selectedSlug ? 'active' : ''}`;
        btn.innerHTML = `<strong>${page.nav_title}</strong><div class="muted" style="font-size:13px; margin-top:4px;">${page.slug}</div>`;
        btn.addEventListener('click', async () => {
          selectedSlug = page.slug;
          await renderDashboard();
        });
        listEl.appendChild(btn);
      });

      document.getElementById('signOutBtn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        location.reload();
      });

      document.getElementById('saveBtn')?.addEventListener('click', saveCurrent);
    }

    function previewPath(slug) {
      switch (slug) {
        case 'notice': return '/notice';
        case 'terms': return '/terms';
        case 'rules': return '/rules';
        case 'commands': return '/commands';
        case 'guide-basic': return '/guide/basic';
        case 'guide-life': return '/guide/life';
        default: return '/';
      }
    }

    async function saveCurrent() {
      const saveAlert = document.getElementById('saveAlert');
      saveAlert.className = 'alert';
      saveAlert.style.display = 'block';
      saveAlert.textContent = '저장 중...';

      const payload = {
        slug: selectedSlug,
        nav_title: document.getElementById('navTitle').value.trim(),
        page_title: document.getElementById('pageTitle').value.trim(),
        excerpt: document.getElementById('excerpt').value.trim(),
        content_md: document.getElementById('contentMd').value,
        updated_at: new Date().toISOString()
      };

      const { error } = await supabase
        .from('site_pages')
        .upsert(payload, { onConflict: 'slug' });

      if (error) {
        saveAlert.className = 'alert err';
        saveAlert.textContent = `저장 실패: ${error.message}`;
        return;
      }

      saveAlert.className = 'alert ok';
      saveAlert.textContent = '저장 완료. 배포 없이 바로 반영돼.';
      await loadPages();
      await renderDashboard();
    }

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function escapeTextarea(value) {
      return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    boot();
  </script>
</BaseLayout>
