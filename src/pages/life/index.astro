---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pages = [
  { href: '/life/miner', title: '광부', text: '광물 채굴과 커스텀 광맥을 통해 성장하는 생활', stats: '근로 · 지식 · 행운' },
  { href: '/life/fisher', title: '어부', text: '등급 물고기, 미니게임, 보물과 조각이 핵심인 생활', stats: '근로 · 행운 · 지식' },
  { href: '/life/farmer', title: '농부', text: '커스텀 작물 재배와 수확 효율에 특화된 생활', stats: '근로 · 감각 · 행운' },
  { href: '/life/chef', title: '요리사', text: '레시피 조리, 성공률, 등급 요리 제작 중심 생활', stats: '근로 · 지식 · 행운 · 감각' },
];
const commonStats = ['근로', '지식', '감각', '행운', '흥정(준비중)', '명성(준비중)'];
---
<BaseLayout title="생활 콘텐츠 | 츄르월드" description="생활 카테고리 허브" pathname="/life">
  <section class="doc-shell">
    <div class="doc-hero">
      <span class="eyebrow">LIFE CONTENTS</span>
      <h1>생활 콘텐츠</h1>
      <p class="muted">각 생활 카테고리를 클릭하면 상세 정보 페이지로 이동하게 구성했어.</p>
    </div>

    <div class="grid-3" style="margin-bottom:18px;">
      <div class="card"><h3>생활 직업</h3><p>광부 / 어부 / 농부 / 요리사 4종을 중심으로 성장하는 구조야.</p></div>
      <div class="card"><h3>숙련도</h3><p>각 생활은 별도의 숙련도 레벨과 스킬 포인트를 따로 관리해.</p></div>
      <div class="card"><h3>마나</h3><p>액티브 스킬에 사용하는 공통 자원. 기본 최대 마나는 100이야.</p></div>
    </div>

    <div class="card" style="margin-bottom:18px;">
      <h3 style="margin-bottom:12px;">공용 스탯</h3>
      <div class="pill-list">
        {commonStats.map((item) => <span class="pill">{item}</span>)}
      </div>
    </div>

    <div class="grid-2">
      {pages.map((item) => (
        <a href={item.href} class="card link-card" aria-label={`${item.title} 상세 보기`}>
          <span class="tag">생활</span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          <div class="pill-list" style="margin-top:auto;"><span class="pill">핵심 스탯: {item.stats}</span></div>
          <span class="link-hint">클릭 가능</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
