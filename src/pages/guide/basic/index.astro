---
import DocLayout from '../../../layouts/DocLayout.astro';
const basicCards = [
  { title: '서버 및 월드', text: '서버 구조와 월드 이용 흐름을 안내하는 기본 가이드', status: '준비 중' },
  { title: '마을', text: '클레임, 그룹, 마을원, 조공, 경작지까지 정리된 핵심 정착 콘텐츠', href: '/guide/basic/village', status: '상세 보기' },
  { title: '잠수 의자', text: '앉아서 별을 캐고 판매하는 잠수 시스템 안내', href: '/guide/basic/diving-chair', status: '상세 보기' },
  { title: '엘리베이터', text: '설치 조건과 이동 방법을 정리할 예정인 문서', status: '추가 예정' },
  { title: '상점', text: '서버 상점과 개인 상점 이용법을 정리할 예정인 문서', status: '추가 예정' },
  { title: '가방', text: '가방 확장, 사용 방법, 주의사항을 정리할 예정인 문서', status: '추가 예정' },
  { title: '우편함', text: '아이템 전달과 수령 흐름을 정리할 예정인 문서', status: '추가 예정' },
  { title: '길라잡이', text: '처음 온 유저가 따라가기 좋은 동선 안내 문서', status: '추가 예정' },
];
---
<DocLayout title="기본 콘텐츠" badge="기본 콘텐츠" description="서버 입문에 필요한 핵심 시스템을 클릭형으로 정리한 허브" pathname="/guide/basic">
  <section class="section-head" style="margin-bottom:18px;">
    <div>
      <div class="kicker">basic contents hub</div>
      <h2>기본 콘텐츠 허브</h2>
      <p>처음 적응할 때 자주 찾는 시스템을 한 곳에 모아뒀어. 상세 내용이 준비된 항목은 바로 들어가서 확인할 수 있어.</p>
    </div>
  </section>

  <div class="grid-2 basic-hub-grid">
    {basicCards.map((item) => (
      item.href ? (
        <a href={item.href} class="card link-card guide-card">
          <span class="tag">기본 콘텐츠</span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          <span class="link-hint">{item.status}</span>
        </a>
      ) : (
        <div class="card guide-card guide-card--static">
          <span class="tag">기본 콘텐츠</span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          <span class="soon-badge">{item.status}</span>
        </div>
      )
    ))}
  </div>

  <section style="margin-top:22px;">
    <div class="card notice-box">
      <h3 style="margin-top:0;">현재 열람 가능한 상세 문서</h3>
      <p>지금은 <strong>마을</strong>과 <strong>잠수 의자</strong>가 먼저 정리되어 있어. 나머지 기본 콘텐츠도 같은 방식으로 계속 추가하면 돼.</p>
    </div>
  </section>
</DocLayout>
